# ─── .env.cpanel.example ──────────────────────────────────────────────────────
# Copy to .env on the cPanel server (NOT in your repo, NOT in public_html).
# After copying:
#   chmod 600 .env
#   php artisan key:generate
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=Cookiely
APP_ENV=production
APP_KEY=                                    # filled by `php artisan key:generate`
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://cookiely.site

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# ── Logging ───────────────────────────────────────────────────────────────────
# `daily` rotates and keeps 14 days — better than `single` on shared hosting.
LOG_CHANNEL=daily
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning                           # error+warning only in prod

# ── Database ──────────────────────────────────────────────────────────────────
# cPanel prefixes DB and user names with your cPanel username.
# E.g. if cPanel user is `mycpuser` and you created DB `cookiely_app`,
# the actual name is `mycpuser_cookiely_app`.
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=mycpuser_cookiely_app
DB_USERNAME=mycpuser_cookiely_dbuser
DB_PASSWORD=

# ── Sessions / cache / queues ─────────────────────────────────────────────────
# All driven by the database — no Redis on most cPanel plans.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true                  # HTTPS only
SESSION_SAME_SITE=lax

CACHE_STORE=database
CACHE_PREFIX=cookiely

QUEUE_CONNECTION=database

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ── Mail ──────────────────────────────────────────────────────────────────────
# Option A: cPanel mailbox (lowest deliverability — fine for internal/ops mail).
MAIL_MAILER=smtp
MAIL_HOST=mail.cookiely.site
MAIL_PORT=465
MAIL_USERNAME=no-reply@cookiely.site
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="no-reply@cookiely.site"
MAIL_FROM_NAME="${APP_NAME}"

# Option B: Postmark / Resend / SES (recommended for customer-facing mail).
# Uncomment and replace the cPanel block above.
# MAIL_MAILER=postmark
# POSTMARK_TOKEN=

# ── Stripe (licensing / billing) ──────────────────────────────────────────────
# Fill these once Stripe is wired up.
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# ── Optional: error monitoring ────────────────────────────────────────────────
# Free tier covers most small-SaaS volumes.
# SENTRY_LARAVEL_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Vite ──────────────────────────────────────────────────────────────────────
# Built locally and shipped via rsync; nothing to set here.

# ── Trust proxies (cPanel runs behind LiteSpeed / shared front-end) ───────────
# Leaving as `*` is OK for cPanel where the proxy is the same host. If your
# cPanel is fronted by Cloudflare, set this to Cloudflare's IP ranges.
TRUSTED_PROXIES=*
